rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.admin == true;
    }

    // Users can read any profile, but can only write their own. Admins can do anything.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // Gardener listings
    match /gardeners/{doc} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (request.auth.uid == resource.data.userId || isAdmin());

      // Ratings: any logged-in user can read/write their own rating
      match /ratings/{ratingId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && (request.auth.uid == ratingId || isAdmin());
      }

      // Comments: any logged-in user can read and create
      match /comments/{commentId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow delete: if request.auth != null && (request.auth.uid == resource.data.authorId || isAdmin());
      }
    }

    // Job listings
    match /jobs/{doc} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (request.auth.uid == resource.data.postedBy || isAdmin());

      // Comments: any logged-in user can read and create
      match /comments/{commentId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow delete: if request.auth != null && (request.auth.uid == resource.data.authorId || isAdmin());
      }
    }

    // Chats: only participants can read or update. Admins can do anything.
    match /chats/{chatId} {
      allow read: if request.auth != null && (request.auth.uid in resource.data.participants || isAdmin());
      allow create: if request.auth != null && request.auth.uid in request.resource.data.participants;
      allow update: if request.auth != null && (request.auth.uid in resource.data.participants || isAdmin());
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read, write: if request.auth != null;
      }
    }

    // Banned users: only admins can write
    match /banned_users/{userId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
  }
}
